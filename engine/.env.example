# AGENT-33 Engine Configuration

# API
API_PORT=8000
API_LOG_LEVEL=info
API_SECRET_KEY=change-me-in-production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_PORT=3000
FRONTEND_API_BASE_URL=http://localhost:8000

# Ollama / default model
# Leave blank to keep the runtime default. Examples:
# DEFAULT_MODEL=openrouter/auto
# DEFAULT_MODEL=openrouter/openai/gpt-5.2
DEFAULT_MODEL=
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=llama3.2:3b
OLLAMA_CONTEXT_LENGTH=32768
# KV cache quantization: q8_0 halves KV cache memory, ~30-40% faster inference.
# Requires flash attention. Set to "" to disable.
OLLAMA_KV_CACHE_TYPE=q8_0
OLLAMA_FLASH_ATTENTION=1

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://agent33:agent33@postgres:5432/agent33
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# NATS
NATS_URL=nats://nats:4222
NATS_PORT=4222

# Security
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ENCRYPTION_KEY=
AUTH_BOOTSTRAP_ENABLED=true
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=admin
AUTH_BOOTSTRAP_ADMIN_SCOPES=admin,agents:read,agents:write,agents:invoke,workflows:read,workflows:write,workflows:execute,tools:execute
COMPONENT_SECURITY_SCAN_STORE_ENABLED=false
COMPONENT_SECURITY_SCAN_STORE_DB_PATH=var/component_security_scans.sqlite3
COMPONENT_SECURITY_SCAN_STORE_RETENTION_DAYS=90

# Ingestion durability
INGESTION_DB_PATH=var/ingestion.db
INGESTION_MAILBOX_DB_PATH=var/ingestion_mailbox.db
INGESTION_JOURNAL_DB_PATH=var/ingestion_journal.db
INGESTION_JOURNAL_RETENTION_DAYS=90
INGESTION_TASK_METRICS_DB_PATH=var/ingestion_task_metrics.db
INGESTION_TASK_METRICS_RETENTION_DAYS=30

# Workflow SSE schema rollout (v1 remains default unless explicitly enabled)
SSE_SCHEMA_V2_ENABLED=false
# Emergency kill switch file: /tmp/agent33_disable_sse_v2

# Local orchestration engine (llama.cpp via OpenAI-compatible API)
LOCAL_ORCHESTRATION_ENGINE=llama.cpp
LOCAL_ORCHESTRATION_MODEL=qwen3-coder-next
LOCAL_ORCHESTRATION_FORMAT=gguf_q4_k_m
LOCAL_ORCHESTRATION_BASE_URL=http://host.docker.internal:8033/v1

# Optional: OpenAI-compatible provider
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=AGENT-33
OPENROUTER_APP_CATEGORY=cli-agent

# Embedding dimension (must match your embedding model output)
# nomic-embed-text=768, text-embedding-3-large=1536, jina-embeddings-v3=1024
EMBEDDING_DIM=768

# TurboQuant-style embedding compression in cache (rotation + scalar quantization)
# Reduces cache memory ~8× at 4 bits with <1% cosine similarity error.
EMBEDDING_QUANTIZATION_ENABLED=true
EMBEDDING_QUANTIZATION_BITS=4
EMBEDDING_QUANTIZATION_SEED=42

# Effort-based model routing (routes tasks to different models by complexity)
# Set to true and configure model slots to enable dynamic LLM assignment.
AGENT_EFFORT_ROUTING_ENABLED=false
AGENT_EFFORT_LOW_MODEL=
AGENT_EFFORT_MEDIUM_MODEL=
AGENT_EFFORT_HIGH_MODEL=

# Observability effort telemetry export
OBSERVABILITY_EFFORT_EXPORT_ENABLED=false
OBSERVABILITY_EFFORT_EXPORT_PATH=var/effort_routing_events.jsonl
OBSERVABILITY_EFFORT_EXPORT_FAIL_CLOSED=false
